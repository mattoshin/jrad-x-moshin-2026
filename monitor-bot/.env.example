# Discord Bot
DISCORD_TOKEN=              # Required - Discord bot token from https://discord.com/developers
BOT_PREFIX=!                # Command prefix (slash commands preferred)

# Stock APIs
FINNHUB_API_KEY=            # Free tier: https://finnhub.io/ (60 calls/min)

# Crypto APIs
COINGECKO_API_KEY=          # Optional - Free tier works without key (30 calls/min)

# Sports APIs
ODDS_API_KEY=               # https://the-odds-api.com/ (500 credits/month free)

# Trading Cards APIs
POKEMON_TCG_API_KEY=        # https://pokemontcg.io/ (20K requests/day free)

# Economic Data
FRED_API_KEY=               # https://fred.stlouisfed.org/docs/api/ (free)

# Testing
WEBHOOK_URL=                # Discord webhook URL for testing embeds

# Whop Integration (monetization)
WHOP_API_KEY=               # https://whop.com/ for subscription management
WHOP_WEBHOOK_SECRET=        # Webhook signing secret from Whop

# Stripe (direct billing)
STRIPE_SECRET_KEY=          # Stripe secret key
STRIPE_WEBHOOK_SECRET=      # Stripe webhook signing secret

# Feature Flags
FREE_TIER_WATERMARK=true    # Show "Powered by MonitorBot" on free-tier embeds
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
