           return view('account-settings');
       }
       return redirect('/login');
   }
   public function gnerateAndSaveApiAuthToken()
   {
       $token =Str::random(60);
       $this->api_token =$token;
       $this->save();
       return $this;
   }


   public function getBusinesses(Request $request)
   {
        

        
        if(!$request->bearerToken()){
            return response([
                "status" => "error",
                "message" => "Missing Authorization Token"
            ], 401);
        }
        $user = User::where('api_token', $request->bearerToken()) -> first();
        if(!$user){
            return response([
                "status" => "error",
                "message" => "Invalid Authorization Token"
            ], 401);
        }
        $userId = $user["id"];
        $servers = collect($this->getGuilds($user["access_token"]));

        $matchThese = ['user' => $userId, 'permission' => '8'];
        $collection = Permissions::where($matchThese)->get();
        $serverids =  $collection->pluck('serverID');
        $serverGuild = Servers::where('owner',$userId)->get();
        
        $filtered = $servers->filter(function($server) use ($serverids) {
            if($serverids->contains($server["id"]) || strstr($server["owner"], 1)){                   
                return $server;
            }
        });
        $results = collect($filtered)
        ->map(function ($row) use ($serverids, $serverGuild) {
            $collection = collect($serverGuild);
            $filteredCollection = $collection->where('guild_id',$row["id"])->first();
            $serverToken=null;
            if ($filteredCollection){
                $filteredBusiness = $filteredCollection->businessToken->api_token;
                if ($filteredBusiness){
                    $serverToken = $filteredBusiness;
                }
            }
            return [
                "id"=>$row["id"],
                "name"=>$row["name"],
                "icon"=>$row["icon"],
                "owner"=>$row["owner"],
                "permission"=>8,
                "token"=>$serverToken
            ];
        });
        $guilds = array();
        foreach ($results as $guild){
            $guild_token = $guild->token ?? null;
            if($guild_token !== null) {
                $guilds = array_merge(array($guild), $guilds);
            } else {
                array_push($guilds, $guild);
            }
        }
        return $guilds;
   }

   
}
