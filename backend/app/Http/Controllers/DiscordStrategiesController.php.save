   public function me(Request $request)
    {
        if(!$request->bearerToken()){
            return response([
                "status" => "error",
                "message" => "Missing Authorization Token"
            ], 401);
        }
        $user = User::where('api_token', $request->bearerToken()) -> first();
        if(!$user){
            return response([
                "status" => "error",
                "message" => "Invalid Authorization Token"
            ], 401);
        }
        return [
            'status' => 'success',
            'user' => [
                "id"=>$user["id"],
                "discordId"=>strval($user["discord_id"]),
                "username"=>$user["username"],
                "email"=>$user["email"],
                "avatar"=>$user["avatar"],
                "creationDate"=>$user["creationDate"],
                "expiresIn"=>$user["expires_in"]
            ]
        ];
    }

    public function messageUser(Request $request){
        $userParam = $request->user;
        $user = User::where('id', $userParam) -> first();
        if(!$user){
            return [
                "status" => "error",
                "message" => "User Not Found"
            ];
        }
        if(!$request->message){
            return [
                "status" => "error",
                "message" => "Empty Message"
            ];
        }
        $response = Http::withHeaders([
            "Content-Type" => "application/json",
            "Content-Length" => "0",
            "Authorization" => "Bot " . env('DISCORD_BOT_TOKEN'),
        ])->post("https://discordapp.com/api/users/@me/channels", [
            "recipient_id" => $user->discord_id
        ]);
        $channel = json_decode($response->getbody(), true)["id"];
        $xo = Http::withHeaders([
            "Content-Type" => "application/json",
            "Content-Length" => "0",
            "Authorization" => "Bot " . env('DISCORD_BOT_TOKEN'),
        ])->post("https://discordapp.com/api/channels/".$channel."/messages", [
            "content" => $request->message
        ]);
        return $xo->getbody();
    }

    function getGuilds($token)
    { 
        $info_request = "https://discordapp.com/api/v6/users/@me/guilds";
        $response = Http::withToken($token)->get($info_request);
        $response->throw();
        $guilds = json_decode($response->getbody(), true);
        return $guilds;
      }

    public function refresh()
    {
        return response()->json([
            'status' => 'success',
            'user' => Auth::user(),
            'authorization' => [
                'token' => Auth::refresh(),
                'type' => 'bearer',
            ]
        ]);
    }

   public function logout(Request $request)
   {
        \Cookie::expire('admin');
        Auth::logout();
        return redirect('/home');
   }
   public function account(Request $request){
