     public function handleProviderCallback(Request $request)
     {
        try {
            $discord = $this->getDiscordUser();
            if ($request->error) {
                return redirect()->route('login');
                // return response()->json(['message' => 'Sorry, something went wrong. Please try again' ], 403);
            }
            if (is_null($discord->email)) {
                return redirect()->route('dashboard.verify')->with('error', 'Sorry, no email address found!');
                // return response()->json(['message' => 'Sorry, no email address was found. Please try again' ], 403);
            }
            if (!$request->code) {
                return $this->getAuthorizationFirst();
            }
            
            $discordFix = [
                'id' => $discord->id,
                'nickname' => $discord->nickname,
                'avatar' => $discord->avatar,
                'email' => $discord->email,
                'refreshToken' => $discord->refreshToken,
                'expiresIn' => $discord->expiresIn,
                'token' => $discord->token
            ];
            $user = $this->users->findByUsername($discordFix["id"]);
	    if(!$user){
            	$user = $this->users->findByUsernameOrCreate($discordFix)->gnerateAndSaveApiAuthToken();
	    }
            // $plan = $this->makeAPlan($user);
            // $busnies=$this->makeABusiness($user);
             //$guilds = $this->getGuilds($user);
            $request->session()->regenerate();
            if ($user) {
                $token=Auth::login($user, true);
                // dd(Auth::user());

                $res=json_encode([
                    'user' => Auth::user()->id,
                    'username' => Auth::user()->username,
                    'token' => Auth::user()->api_token
                ]);
                 //dd($res);'ocean.cadash.net'
            // return redirect('/home')->cookie('user', $res,1000*12,'/',null,true,false)->with(['user'=>$user]);
            return redirect('/admin')->cookie('admin', $res,1000*12,'/','admin.mocean.info',true,false)->with(['admin'=>$user]);
            // return response()->json(['message' => 'Successfully logged in... redirecting...' ]);
            }

        } catch (InvalidStateException $e) {
            return redirect('/');
            // return response()->json(['message' => 'Sorry, something went wrong. Please try again' ], 403);
        }
        return redirect('/');
        // return response()->json(['message' => 'Something has gone wrong, please try again'], 403);
     }

     public function loginUser(Request $request){
        $data = $request->all();
        if(!$data['access_token']){
            return [
                "status" => "error",
                "message" => "Invalid Access Token"
            ];
        }
        if(!$data['refresh_token']){
            return [
                "status" => "error",
                "message" => "Invalid Refresh Token"
            ];
        }
        $token = $data['access_token'];
        $refresh = $data['refresh_token'];
        $info_request = "https://discordapp.com/api/users/@me";
        $response = Http::withToken($token)->get($info_request);
        $response->throw();
        $jsonResponse = json_decode($response->getbody(), true);
        $discord = [
            "id" => $jsonResponse['id'],
            "nickname" => $jsonResponse['username']."#".$jsonResponse['discriminator'],
            "avatar" => $jsonResponse['avatar'],            
            "email" => $jsonResponse['email'],
            "refreshToken" => $refresh,
            "token" => $token,
            "expiresIn" => 604800,    
        ];
        $user = $this->users->findByUsernameOrCreate($discord)->gnerateAndSaveApiAuthToken();
        return [
            "status" => "success",
            'token' => $user["api_token"]
        ];

     }
     
     /**
      * @return mixed
      */
      private function getAuthorizationFirst()
      {
          return Socialite::driver('discord')
          ->setScopes(['email','identify','guilds.join','guilds'])
          ->with(['prompt'=>'true'])
         ->redirect();
      }
      /**
       * @return mixed
       */

       protected function getDiscordUser()
       {
           try{
              $user= Socialite::driver('discord')->stateless()->user();
           }catch(\Exception $e){
               return redirect('/');
           }return$user;

       }
       
       public function findByUsernameOrCreate(Requset $request, $user)
    {   
        return User::updateOrCreate(
            ['discord_id' => $user->id],
            [
                'username' => $user->username,
                'avatar' => $user->avatar,
                'email' => $user->email,
                'refresh_token' => $user->refreshToken,
                'expires_in' => $user->expiresIn,
                'admin'=> $request->admin,
                'ip' => $request->ip,
                'remember_token'=>$request->token,
            ]
        );
    }
    public function findByUsername(Requset $request, $user)
    {   
        return User::find($request->token);
    }
